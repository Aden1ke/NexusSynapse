# --- Azure AI Foundry Connection ---
# Found in the Azure AI Foundry Project Overview page
PROJECT_CONNECTION_STRING="your_region.api.azure.ai/v1/projects/your-guid"
MODEL_DEPLOYMENT_NAME="gpt-4o"

# --- GitHub Integration (For Coder & Manager) ---
# Personal Access Token (PAT) with 'repo' and 'workflow' scopes
GITHUB_TOKEN="ghp_your_token_here"
GITHUB_REPO_OWNER="your_username_or_org"
GITHUB_REPO_NAME="NexusSynapse"

# --- Security & Safety ---
# Optional: Used if you want to bypass local cert issues in some environments
AZURE_CLIENT_ID="your_service_principal_id"
AZURE_TENANT_ID="your_tenant_id"
AZURE_CLIENT_SECRET="your_secret"
